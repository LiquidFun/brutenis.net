---
import "@styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Brutenis's personal website - a yarn-tangled corner of the internet" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

<title>{title} | brutenis.net</title>
    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Game canvas (behind content) -->
    <canvas id="yarn-game-canvas" class="yarn-canvas yarn-canvas-game" transition:persist="yarn-game-canvas"></canvas>
    <!-- Cursor canvas (above content) -->
    <canvas id="yarn-cursor-canvas" class="yarn-canvas yarn-canvas-cursor" transition:persist="yarn-cursor-canvas"></canvas>
    <!-- Game HUD + attackers toggle -->
    <div id="game-hud" class="game-hud" title="Start Game" transition:persist="game-hud">
      <span class="hud-sword">&#x2694;</span>
      <span id="hud-disable-label" class="font-heading text-lg hud-label">Disable Game</span>
      <span id="hud-separator" class="hud-separator" style="display:none">|</span>
      <span id="game-score-wrap" class="font-heading text-lg hud-score" style="display:none">Defended: <span id="game-score">0</span></span>
      <span class="hud-dismiss">&times;</span>
    </div>
    <!-- Game over overlay -->
    <div id="game-over-overlay" class="game-over-overlay" style="display:none" transition:persist="game-over-overlay">
      <div class="game-over-box">
        <h2 class="font-heading text-6xl font-bold text-yarn-coral mb-2">Game Over!</h2>
        <p class="font-heading text-2xl text-text-charcoal mb-1">Defended <span id="game-over-score">0</span> attacks</p>
        <p class="font-heading text-xl text-text-muted">Reached Level <span id="game-over-level">1</span></p>
        <button id="try-again-btn" class="try-again-btn">Try Again</button>
        <button id="disable-attackers-btn" class="disable-attackers-btn">Disable Attackers</button>
      </div>
    </div>
    <!-- Gyro permission overlay (iOS mobile only) -->
    <div id="gyro-permission-overlay" class="game-over-overlay" style="display:none" transition:persist="gyro-permission-overlay">
      <div class="gyro-permission-box">
        <p class="font-heading text-2xl text-text-charcoal mb-3">Tilt to play!</p>
        <p class="font-body text-text-muted mb-4">
          Tilt your phone to bounce the yarn ball and defend your blog posts from monsters.
        </p>
        <button id="gyro-grant-btn" class="try-again-btn">Enable Gyroscope</button>
        <button id="gyro-skip-btn" class="disable-attackers-btn">No thanks</button>
      </div>
    </div>

    <nav class="sticky top-0 z-50 bg-bg-cream/90 backdrop-blur-sm border-b-2 border-dashed border-yarn-coral/30">
      <div class="max-w-5xl mx-auto px-4 py-1 flex flex-col items-center sm:flex-row sm:items-center sm:justify-between gap-0 sm:gap-0 sm:py-3">
        <a href="/" class="logo-link" id="animated-logo">
          brutenis.net
        </a>
        <div class="flex gap-0 sm:gap-1 items-center flex-wrap justify-center sm:justify-start">
          <a href="/blog" class="nav-link">Blog</a>
          <a href="/projects" class="nav-link">Projects</a>
          <a href="/games" class="nav-link">Games</a>
          <a href="/ctf" class="nav-link">CTF</a>
          <a href="/about" class="nav-link">About</a>
        </div>
      </div>
    </nav>

    <main class="flex-1 max-w-5xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>

    <footer class="border-t-2 border-dashed border-yarn-teal/30 mt-auto">
      <div class="max-w-5xl mx-auto px-4 py-6 text-center text-text-muted text-sm">
        <p class="font-heading text-lg">&copy; {new Date().getFullYear()} brutenis.net</p>
        <div class="flex justify-center gap-4 mt-2">
          <a href="https://github.com/LiquidFun" class="hover:text-yarn-coral transition-colors">GitHub</a>
          <a href="/rss.xml" class="hover:text-yarn-coral transition-colors">RSS</a>
        </div>
        <p class="mt-3 text-xs text-text-muted/50 font-heading">Use the yarn ball to defend the blog entries</p>
      </div>
    </footer>

    <script>
      import "@scripts/yarn-cursor/index";
      import "@scripts/yarn-game/index";
      import "@scripts/animated-logo";
      import "@scripts/clickable-cards";
    </script>
  </body>
</html>

<style>
  .nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--color-text-charcoal);
    transition: all 0.2s;
  }
  .nav-link:hover {
    background-color: var(--color-bg-warm);
    color: var(--color-yarn-coral);
  }

  .yarn-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .yarn-canvas-game {
    z-index: 60;
    pointer-events: none;
  }

  .yarn-canvas-cursor {
    z-index: 61;
    pointer-events: none;
  }

  .logo-link {
    font-family: var(--font-heading);
    font-size: 1.875rem;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s;
    display: inline-block;
    width: 264px;
    height: 53px;
    color: transparent;
  }
  .logo-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 639px) {
    .nav-link {
      font-size: 1rem;
      padding: 0.25rem 0.5rem;
    }
  }

  .hud-sword {
    font-size: 1.1rem;
    line-height: 1;
    color: var(--color-yarn-coral);
  }

  .hud-label {
    color: var(--color-text-muted);
  }

  .hud-separator {
    color: var(--color-text-muted);
    opacity: 0.4;
  }

  .hud-score {
    color: var(--color-text-charcoal);
  }

  .hud-dismiss {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    line-height: 1;
    margin-left: 0.1rem;
    opacity: 0.5;
  }

  .game-hud {
    position: fixed;
    top: calc(100dvh - 5.5rem);
    right: 50%;
    transform: translateX(50%);
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(4px);
    padding: 0.5rem 1.2rem;
    border-radius: 2rem;
    border: 2px solid rgba(255, 107, 107, 0.3);
    box-shadow: 0 2px 16px rgba(255, 107, 107, 0.15), 0 2px 8px rgba(0, 0, 0, 0.08);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
    cursor: pointer;
    user-select: none;
    transition: top 0.5s ease, right 0.5s ease, transform 0.5s ease,
                padding 0.3s ease, border-radius 0.3s ease,
                gap 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
  }

  @media (min-width: 640px) {
    .game-hud {
      top: calc(100dvh - 12rem);
    }
  }

  .game-hud-collapsed {
    top: 0.5rem;
    right: 0.5rem;
    transform: none;
    padding: 0;
    border-radius: 50%;
    background: var(--color-yarn-coral);
    box-shadow: 0 2px 8px rgba(255, 107, 107, 0.4);
    width: 2.5rem;
    height: 2.5rem;
    justify-content: center;
    gap: 0;
    cursor: pointer;
  }

  .game-hud-collapsed .hud-sword {
    color: white;
    font-size: 1.3rem;
  }

  .game-hud-collapsed .hud-label,
  .game-hud-collapsed .hud-separator,
  .game-hud-collapsed .hud-score,
  .game-hud-collapsed .hud-dismiss {
    display: none;
  }

  @media (min-width: 640px) {
    .game-hud-collapsed {
      width: 3rem;
      height: 3rem;
      top: 0.55rem;
      right: 0.55rem;
    }
    .game-hud-collapsed .hud-sword {
      font-size: 1.6rem;
    }
  }


  .canvas-greyed {
    filter: grayscale(0.8) brightness(0.6);
    transition: filter 0.5s ease;
  }

  .game-over-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(45, 52, 54, 0.5);
    backdrop-filter: blur(3px);
  }
  .game-over-box {
    text-align: center;
    background: var(--color-bg-cream);
    padding: 2.5rem 3rem;
    border-radius: 1rem;
    border: 3px dashed var(--color-yarn-coral);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
  }
  .try-again-btn,
  .disable-attackers-btn {
    margin-top: 0.5rem;
    padding: 0.6rem 2rem;
    border: 2px solid transparent;
    border-radius: 0.75rem;
    font-family: var(--font-heading);
    font-size: 1.4rem;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
    box-sizing: border-box;
  }
  .try-again-btn {
    margin-top: 1rem;
    background: var(--color-yarn-coral);
    color: white;
    border-color: var(--color-yarn-coral);
  }
  .try-again-btn:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    transform: translateY(-2px);
  }
  .disable-attackers-btn {
    background: transparent;
    color: var(--color-text-muted);
    border-color: var(--color-text-muted);
    border-style: dashed;
  }
  .disable-attackers-btn:hover {
    background: var(--color-text-muted);
    color: white;
    transform: translateY(-2px);
  }

  .gyro-permission-box {
    text-align: center;
    background: var(--color-bg-cream);
    padding: 2rem 2.5rem;
    border-radius: 1rem;
    border: 3px dashed var(--color-yarn-teal);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
    max-width: 85vw;
  }
</style>
