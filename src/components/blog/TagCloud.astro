---
import TagPill from "./TagPill.astro";

interface Props {
  tags: string[];
  activeTag?: string;
}

const { tags, activeTag } = Astro.props;
---

<div class="tag-cloud flex flex-wrap gap-2 mb-8">
  <a
    href="/blog"
    class:list={[
      "tag-pill-all",
      { active: !activeTag },
    ]}
    data-tag-filter=""
  >
    all
  </a>
  {tags.map((tag) => (
    <span data-tag-filter={tag}>
      <TagPill tag={tag} active={tag === activeTag} />
    </span>
  ))}
</div>

<script>
  function initTagHoverFilter() {
    const filters = document.querySelectorAll("[data-tag-filter]");
    const cards = document.querySelectorAll("[data-tags]");

    for (const filter of filters) {
      const tag = (filter as HTMLElement).dataset.tagFilter;

      filter.addEventListener("mouseenter", () => {
        if (!tag) {
          // "all" — show everything
          for (const card of cards) {
            (card as HTMLElement).style.opacity = "";
            (card as HTMLElement).style.transform = "";
          }
          return;
        }

        for (const card of cards) {
          const cardTags = (card as HTMLElement).dataset.tags?.split(",") || [];
          if (cardTags.includes(tag)) {
            (card as HTMLElement).style.opacity = "1";
            (card as HTMLElement).style.transform = "";
          } else {
            (card as HTMLElement).style.opacity = "0.25";
            (card as HTMLElement).style.transform = "scale(0.98)";
          }
        }
      });

      filter.addEventListener("mouseleave", () => {
        for (const card of cards) {
          (card as HTMLElement).style.opacity = "";
          (card as HTMLElement).style.transform = "";
        }
      });
    }
  }

  initTagHoverFilter();
  document.addEventListener("astro:page-load", initTagHoverFilter);
</script>

<style>
  .tag-pill-all {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    border: 2px dashed var(--color-text-muted);
    border-radius: 9999px;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    transition: all 0.2s;
    text-decoration: none;
  }
  .tag-pill-all:hover,
  .tag-pill-all.active {
    background-color: var(--color-text-charcoal);
    color: white;
    border-color: var(--color-text-charcoal);
  }
</style>
