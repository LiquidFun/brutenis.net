---
---

<div class="verlet-diagram">
  <canvas id="verlet-diagram-canvas"></canvas>
  <p class="verlet-diagram-caption">
    One constraint-solving pass: each correction only moves points partway, and
    fixing one segment can undo its neighbors
  </p>
</div>

<style>
  .verlet-diagram {
    max-width: 600px;
    margin: 1.5rem auto 2rem;
    border: 2px dashed var(--color-yarn-teal);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  #verlet-diagram-canvas {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 2;
  }

  .verlet-diagram-caption {
    text-align: center;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    padding: 0.5rem 1rem;
    margin: 0;
    border-top: 1px dashed var(--color-yarn-teal);
  }
</style>

<script>
  function initVerletDiagram() {
    const canvas = document.getElementById(
      "verlet-diagram-canvas",
    ) as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;
    if ((canvas as any)._vdInit) return;
    (canvas as any)._vdInit = true;

    // ── Colors ──
    const CORAL = "#ff6b6b";
    const TEAL = "#4ecdc4";
    const PURPLE = "#a06cd5";
    const CHARCOAL = "#2d3436";
    const MUTED = "#636e72";
    const BLUE = "#74b9ff";

    // ── Config ──
    const N = 5;
    const POS_A = { x: 0.25, y: 0.28 };
    const POS_B = { x: 0.75, y: 0.22 };
    const SEG_FRAC = 0.15;
    const DAMPING = 0.98;
    const ARROW_SCALE = 0.5; // show arrows at 50% of actual velocity
    const DUR = {
      rest: 1.5,
      move: 1.0,
      step: 0.6,
      pause: 1.5,
      physics: 1.0,
    };

    // ── State ──
    let w = 0;
    let h = 0;
    let segLen = 0;
    let mouse = { x: 0, y: 0 };
    let pts: { x: number; y: number }[] = [];
    let state = "REST_A";
    let time = 0;
    // Constraint solve
    let si = 0;
    let sfa = { x: 0, y: 0 };
    let sta = { x: 0, y: 0 };
    let sfb = { x: 0, y: 0 };
    let stb = { x: 0, y: 0 };
    // Rest lerp
    let rf: { x: number; y: number }[] = [];
    let rt: { x: number; y: number }[] = [];
    // Physics / momentum
    let preSolvePts: { x: number; y: number }[] = [];
    let vels: { x: number; y: number }[] = [];
    let physFrom: { x: number; y: number }[] = [];
    let physTo: { x: number; y: number }[] = [];

    // ── Helpers ──
    const ease = (t: number) =>
      t < 0.5 ? 4 * t * t * t : 1 - (-2 * t + 2) ** 3 / 2;
    const mix = (a: number, b: number, t: number) => a + (b - a) * t;
    const pA = () => ({ x: w * POS_A.x, y: h * POS_A.y });
    const pB = () => ({ x: w * POS_B.x, y: h * POS_B.y });

    function makeRope(anchor: { x: number; y: number }) {
      return Array.from({ length: N }, (_, i) => ({
        x: anchor.x,
        y: anchor.y + i * segLen,
      }));
    }

    // ── Canvas sizing ──
    function resize() {
      const r = canvas.getBoundingClientRect();
      const d = devicePixelRatio || 1;
      canvas.width = r.width * d;
      canvas.height = r.height * d;
      ctx.setTransform(d, 0, 0, d, 0, 0);
      w = r.width;
      h = r.height;
      segLen = h * SEG_FRAC;
      const a = pA();
      mouse = { ...a };
      pts = makeRope(a);
      preSolvePts = makeRope(a);
      rf = makeRope(a);
      rt = makeRope(a);
      state = "REST_A";
      time = 0;
    }

    const obs = new ResizeObserver(resize);
    obs.observe(canvas);
    resize();

    // ── State transitions ──
    // Uses the real Verlet constraint formula:
    //   diff = (segLen - dist) / dist / 2
    //   locked point stays, free points move by dx*diff / dy*diff
    function beginSolve(idx: number) {
      si = idx;
      const a = pts[idx];
      const b = pts[idx + 1];
      sfa = { ...a };
      sfb = { ...b };

      const dx = b.x - a.x;
      const dy = b.y - a.y;
      const d = Math.hypot(dx, dy);

      if (d === 0) {
        sta = { ...a };
        stb = { x: a.x, y: a.y + segLen };
      } else {
        const diff = (segLen - d) / d / 2;
        if (idx === 0) {
          sta = { ...a };
          stb = { x: b.x + dx * diff, y: b.y + dy * diff };
        } else {
          sta = { x: a.x - dx * diff, y: a.y - dy * diff };
          stb = { x: b.x + dx * diff, y: b.y + dy * diff };
        }
      }

      time = 0;
    }

    function go(s: string) {
      state = s;
      time = 0;
      if (s === "REST_A") {
        rf = pts.map((p) => ({ ...p }));
        rt = makeRope(pA());
      }
      if (s === "SOLVE_B") {
        // Snapshot positions before solving — used later to compute momentum
        preSolvePts = pts.map((p) => ({ ...p }));
        beginSolve(0);
      }
      if (s === "PHYSICS_A") {
        // Compute velocity: how much each point moved during SOLVE_B, damped
        physFrom = pts.map((p) => ({ ...p }));
        vels = pts.map((p, i) => {
          if (i === 0) return { x: 0, y: 0 };
          return {
            x: (p.x - preSolvePts[i].x) * DAMPING,
            y: (p.y - preSolvePts[i].y) * DAMPING,
          };
        });
        physTo = pts.map((p, i) => ({
          x: p.x + vels[i].x,
          y: p.y + vels[i].y,
        }));
      }
      if (s === "SOLVE_A") {
        preSolvePts = pts.map((p) => ({ ...p }));
        beginSolve(0);
      }
    }

    // ── Update ──
    function update(dt: number) {
      time += dt;

      switch (state) {
        case "REST_A": {
          const t = ease(Math.min(time / DUR.rest, 1));
          for (let i = 0; i < N; i++) {
            pts[i] = {
              x: mix(rf[i].x, rt[i].x, t),
              y: mix(rf[i].y, rt[i].y, t),
            };
          }
          mouse = { ...pts[0] };
          if (time >= DUR.rest) go("MOVE_TO_B");
          break;
        }

        case "MOVE_TO_B": {
          const t = ease(Math.min(time / DUR.move, 1));
          const a = pA();
          const b = pB();
          mouse = { x: mix(a.x, b.x, t), y: mix(a.y, b.y, t) };
          pts[0] = { ...mouse };
          if (time >= DUR.move) go("SOLVE_B");
          break;
        }

        case "SOLVE_B":
        case "SOLVE_A": {
          const t = ease(Math.min(time / DUR.step, 1));
          pts[si] = {
            x: mix(sfa.x, sta.x, t),
            y: mix(sfa.y, sta.y, t),
          };
          pts[si + 1] = {
            x: mix(sfb.x, stb.x, t),
            y: mix(sfb.y, stb.y, t),
          };
          if (time >= DUR.step) {
            pts[si] = { ...sta };
            pts[si + 1] = { ...stb };
            if (si < N - 2) {
              beginSolve(si + 1);
            } else {
              go(state === "SOLVE_B" ? "PAUSE_B" : "PAUSE_A");
            }
          }
          break;
        }

        case "PAUSE_B":
          if (time >= DUR.pause) go("MOVE_TO_A");
          break;

        case "MOVE_TO_A": {
          const t = ease(Math.min(time / DUR.move, 1));
          const a = pA();
          const b = pB();
          mouse = { x: mix(b.x, a.x, t), y: mix(b.y, a.y, t) };
          pts[0] = { ...mouse };
          if (time >= DUR.move) go("PHYSICS_A");
          break;
        }

        case "PHYSICS_A": {
          const t = ease(Math.min(time / DUR.physics, 1));
          for (let i = 1; i < N; i++) {
            pts[i] = {
              x: mix(physFrom[i].x, physTo[i].x, t),
              y: mix(physFrom[i].y, physTo[i].y, t),
            };
          }
          if (time >= DUR.physics) go("SOLVE_A");
          break;
        }

        case "PAUSE_A":
          if (time >= DUR.pause) go("REST_A");
          break;
      }
    }

    // ── Drawing ──
    function drawCursorIcon(x: number, y: number) {
      ctx.save();
      ctx.translate(x, y);
      ctx.fillStyle = PURPLE;
      ctx.strokeStyle = "#fff";
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.moveTo(0, 0);
      ctx.lineTo(0, 20);
      ctx.lineTo(5.5, 15.5);
      ctx.lineTo(9.5, 24);
      ctx.lineTo(12.5, 22.5);
      ctx.lineTo(8.5, 14);
      ctx.lineTo(15, 14);
      ctx.closePath();
      ctx.fill();
      ctx.stroke();
      ctx.restore();
    }

    function drawYarnBall(x: number, y: number) {
      const r = Math.max(10, segLen * 0.22);

      ctx.beginPath();
      ctx.arc(x, y, r, 0, 2 * Math.PI);
      ctx.fillStyle = CORAL;
      ctx.fill();

      ctx.save();
      ctx.beginPath();
      ctx.arc(x, y, r, 0, 2 * Math.PI);
      ctx.clip();
      ctx.strokeStyle = "#d55";
      ctx.lineWidth = 1.5;
      ctx.globalAlpha = 0.45;
      const arcs = [
        { cx: -0.3, cy: 0, cr: 0.8, a: -0.6, l: 2.5 },
        { cx: 0.2, cy: -0.25, cr: 0.7, a: 0.8, l: 2.2 },
        { cx: 0.05, cy: 0.3, cr: 0.75, a: 2.0, l: 2.3 },
      ];
      for (const o of arcs) {
        ctx.beginPath();
        ctx.arc(x + o.cx * r, y + o.cy * r, o.cr * r, o.a, o.a + o.l);
        ctx.stroke();
      }
      ctx.restore();

      ctx.beginPath();
      ctx.arc(x - r * 0.25, y - r * 0.25, r * 0.22, 0, 2 * Math.PI);
      ctx.fillStyle = "rgba(255,255,255,0.35)";
      ctx.fill();
    }

    function drawArrow(
      x: number,
      y: number,
      dx: number,
      dy: number,
      alpha: number,
    ) {
      const len = Math.hypot(dx, dy);
      if (len < 2) return;

      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.strokeStyle = BLUE;
      ctx.fillStyle = BLUE;
      ctx.lineWidth = 2.5;
      ctx.lineCap = "round";

      const ex = x + dx;
      const ey = y + dy;

      // Shaft
      ctx.beginPath();
      ctx.moveTo(x, y);
      ctx.lineTo(ex, ey);
      ctx.stroke();

      // Arrowhead
      const headLen = Math.min(8, len * 0.4);
      const angle = Math.atan2(dy, dx);
      ctx.beginPath();
      ctx.moveTo(ex, ey);
      ctx.lineTo(
        ex - headLen * Math.cos(angle - 0.45),
        ey - headLen * Math.sin(angle - 0.45),
      );
      ctx.lineTo(
        ex - headLen * Math.cos(angle + 0.45),
        ey - headLen * Math.sin(angle + 0.45),
      );
      ctx.closePath();
      ctx.fill();

      ctx.restore();
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);

      const solving = state === "SOLVE_B" || state === "SOLVE_A";
      const isPhysics = state === "PHYSICS_A";

      // Segment length radius guide during solving
      if (solving) {
        ctx.save();
        ctx.beginPath();
        ctx.arc(pts[si].x, pts[si].y, segLen, 0, 2 * Math.PI);
        ctx.strokeStyle = CORAL;
        ctx.globalAlpha = 0.12;
        ctx.lineWidth = 1.5;
        ctx.setLineDash([5, 5]);
        ctx.stroke();
        ctx.restore();
      }

      // Segments
      for (let i = 0; i < N - 1; i++) {
        ctx.beginPath();
        ctx.moveTo(pts[i].x, pts[i].y);
        ctx.lineTo(pts[i + 1].x, pts[i + 1].y);
        ctx.lineCap = "round";

        if (solving && i === si) {
          ctx.strokeStyle = CORAL;
          ctx.lineWidth = 4;
          ctx.globalAlpha = 1;
        } else if (solving && i < si) {
          ctx.strokeStyle = TEAL;
          ctx.lineWidth = 3;
          ctx.globalAlpha = 0.85;
        } else {
          ctx.strokeStyle = TEAL;
          ctx.lineWidth = 3;
          ctx.globalAlpha = solving ? 0.3 : 0.6;
        }

        ctx.stroke();
        ctx.globalAlpha = 1;
      }

      // Points (skip last — drawn as yarn ball)
      for (let i = 0; i < N - 1; i++) {
        const active = solving && (i === si || i === si + 1);

        ctx.beginPath();
        ctx.arc(pts[i].x, pts[i].y, active ? 7 : 5, 0, 2 * Math.PI);
        ctx.fillStyle = i === 0 ? PURPLE : active ? CORAL : CHARCOAL;
        ctx.fill();

        if (i === 0) {
          ctx.strokeStyle = "#fff";
          ctx.lineWidth = 2;
          ctx.stroke();
        }
      }

      // Yarn ball at last point
      drawYarnBall(pts[N - 1].x, pts[N - 1].y);

      // Velocity arrows — grow during solve steps, persist, then fade in physics
      if (isPhysics) {
        // During physics: use pre-computed velocities, fading as applied
        const alpha = 1 - ease(Math.min(time / DUR.physics, 1)) * 0.7;
        for (let i = 1; i < N; i++) {
          drawArrow(
            pts[i].x,
            pts[i].y,
            vels[i].x * ARROW_SCALE,
            vels[i].y * ARROW_SCALE,
            alpha,
          );
        }
      } else if (state !== "REST_A" && state !== "MOVE_TO_B") {
        // During solve/pause/move: compute from displacement since solve started
        for (let i = 1; i < N; i++) {
          const vx =
            (pts[i].x - preSolvePts[i].x) * DAMPING * ARROW_SCALE;
          const vy =
            (pts[i].y - preSolvePts[i].y) * DAMPING * ARROW_SCALE;
          drawArrow(pts[i].x, pts[i].y, vx, vy, 0.8);
        }
      }

      // Point labels
      ctx.save();
      ctx.font = "12px sans-serif";
      ctx.textAlign = "center";
      ctx.fillStyle = MUTED;
      ctx.globalAlpha = 0.7;
      for (let i = 0; i < N - 1; i++) {
        ctx.fillText(`P${i}`, pts[i].x, pts[i].y - 14);
      }
      const ballR = Math.max(10, segLen * 0.22);
      ctx.fillText(`P${N - 1}`, pts[N - 1].x, pts[N - 1].y - ballR - 6);
      ctx.restore();

      // Cursor icon
      drawCursorIcon(mouse.x, mouse.y);

      // Status label (top-right)
      if (solving) {
        ctx.save();
        ctx.font = "bold 14px sans-serif";
        ctx.textAlign = "right";
        ctx.fillStyle = CORAL;
        ctx.fillText(`Step ${si + 1} / ${N - 1}`, w - 16, 24);
        ctx.restore();
      }
      if (isPhysics) {
        ctx.save();
        ctx.font = "bold 14px sans-serif";
        ctx.textAlign = "right";
        ctx.fillStyle = BLUE;
        ctx.fillText("Momentum", w - 16, 24);
        ctx.restore();
      }
    }

    // ── Reduced motion: static fallback ──
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      draw();
      return;
    }

    // ── Animation loop ──
    let last = 0;
    function loop(t: number) {
      if (!canvas.isConnected) {
        obs.disconnect();
        return;
      }
      const dt = last ? Math.min((t - last) / 1000, 0.1) : 0;
      last = t;
      update(dt);
      draw();
      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);
  }

  initVerletDiagram();
  document.addEventListener("astro:page-load", initVerletDiagram);
</script>
