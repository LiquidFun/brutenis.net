---
import ProjectLayout from "@layouts/ProjectLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const games = await getCollection("games");
  return games.map((game) => ({
    params: { slug: game.id },
    props: game,
  }));
}

const game = Astro.props;
const { Content } = await render(game);
const playUrl = game.data.links?.play;
---

<ProjectLayout
  title={game.data.title}
  description={game.data.description}
  date={game.data.date}
  tags={game.data.tags}
  links={game.data.links}
  media={game.data.media}
  backLink="/games"
  backLabel="Back to games"
>
  {playUrl && (
    <div class="game-embed-wrap mb-8" slot="embed">
      <div class="game-embed" id="game-embed">
        <button class="play-overlay" id="play-btn" data-src={playUrl} data-title={`Play ${game.data.title}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <span>Play in browser</span>
        </button>
      </div>
      <button class="embed-btn" id="mute-btn" title="Mute" style="display:none">
        <svg id="mute-icon-off" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
        </svg>
        <svg id="mute-icon-on" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
          <line x1="23" y1="9" x2="17" y2="15"/>
          <line x1="17" y1="9" x2="23" y2="15"/>
        </svg>
      </button>
      <button class="embed-btn" id="fullscreen-btn" title="Fullscreen" style="display:none">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
        </svg>
      </button>
    </div>
  )}
  <Content />
</ProjectLayout>

<style>
  .game-embed-wrap {
    position: relative;
    max-width: 960px;
    margin-inline: auto;
  }
  .game-embed {
    border: 2px dashed var(--color-yarn-purple);
    border-radius: 0.75rem;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: #1a1a2e;
  }
  .game-embed iframe {
    width: 100%;
    height: 100%;
    border: none;
  }
  .play-overlay {
    width: 100%;
    height: 100%;
    border: none;
    background: none;
    color: rgba(255, 255, 255, 0.8);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: color 0.2s;
  }
  .play-overlay:hover {
    color: white;
  }
  .play-overlay span {
    font-family: var(--font-heading);
    font-size: 1.5rem;
  }
  .embed-btn {
    position: absolute;
    top: 0.5rem;
    background: rgba(0, 0, 0, 0.5);
    color: white;
    border: none;
    border-radius: 0.375rem;
    padding: 0.4rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .embed-btn:hover {
    background: rgba(0, 0, 0, 0.7);
  }
  #mute-btn {
    right: 2.5rem;
  }
  #fullscreen-btn {
    right: 0.5rem;
  }
</style>

<script>
  function initGameEmbed() {
    const playBtn = document.getElementById('play-btn');
    const fsBtn = document.getElementById('fullscreen-btn');
    const muteBtn = document.getElementById('mute-btn');
    if (!playBtn) return;

    let muted = false;

    playBtn.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLElement;
      const src = btn.dataset.src;
      const title = btn.dataset.title || '';
      const embed = document.getElementById('game-embed');
      if (!embed || !src) return;

      const iframe = document.createElement('iframe');
      iframe.src = src;
      iframe.title = title;
      iframe.allowFullscreen = true;
      iframe.id = 'game-iframe';
      iframe.style.width = '100%';
      iframe.style.height = '100%';
      iframe.style.border = 'none';

      embed.replaceChildren(iframe);
      if (fsBtn) fsBtn.style.display = '';
      if (muteBtn) muteBtn.style.display = '';

      // Patch AudioContext in iframe to track all instances
      iframe.addEventListener('load', () => {
        try {
          const win = iframe.contentWindow as any;
          win.__audioContexts = win.__audioContexts || [];
          const Orig = win.AudioContext || win.webkitAudioContext;
          if (Orig && !win.__acPatched) {
            win.__acPatched = true;
            const patched = function(this: AudioContext, ...args: any[]) {
              const ctx = new Orig(...args);
              win.__audioContexts.push(ctx);
              return ctx;
            };
            patched.prototype = Orig.prototype;
            if (win.AudioContext) win.AudioContext = patched;
            if (win.webkitAudioContext) win.webkitAudioContext = patched;
          }
        } catch { /* cross-origin */ }
      });
    });

    muteBtn?.addEventListener('click', () => {
      const iframe = document.getElementById('game-iframe') as HTMLIFrameElement | null;
      if (!iframe) return;
      muted = !muted;

      try {
        const win = iframe.contentWindow as any;
        // Mute all <audio> and <video> elements
        const media = win.document.querySelectorAll('audio, video');
        media.forEach((el: HTMLMediaElement) => { el.muted = muted; });

        // Suspend/resume all tracked AudioContexts
        const contexts: AudioContext[] = win.__audioContexts || [];

        // Also check common Godot globals as fallback
        const candidates = [
          win.GodotAudio?.ctx,
          win.Godot?.audio?.ctx,
          win.Module?.audio_context,
        ];
        for (const ctx of candidates) {
          if (ctx && !contexts.includes(ctx)) contexts.push(ctx);
        }

        for (const ctx of contexts) {
          if (muted) ctx.suspend();
          else ctx.resume();
        }
      } catch { /* cross-origin */ }

      document.getElementById('mute-icon-off')!.style.display = muted ? 'none' : '';
      document.getElementById('mute-icon-on')!.style.display = muted ? '' : 'none';
    });

    fsBtn?.addEventListener('click', () => {
      const embed = document.getElementById('game-embed');
      if (embed) {
        if (document.fullscreenElement) {
          document.exitFullscreen();
        } else {
          embed.requestFullscreen();
        }
      }
    });
  }

  initGameEmbed();
  document.addEventListener('astro:page-load', initGameEmbed);
</script>
