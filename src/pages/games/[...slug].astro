---
import ProjectLayout from "@layouts/ProjectLayout.astro";
import GameEmbed from "@components/projects/GameEmbed.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const games = await getCollection("games");
  return games.map((game) => ({
    params: { slug: game.id },
    props: game,
  }));
}

const game = Astro.props;
const { Content } = await render(game);
const playUrl = game.data.links?.play;
---

<ProjectLayout
  title={game.data.title}
  description={game.data.description}
  date={game.data.date}
  tags={game.data.tags}
  links={game.data.links}
  media={game.data.media}
  backLink="/games"
  backLabel="Back to games"
>
  {playUrl && (
    <GameEmbed playUrl={playUrl} title={game.data.title} slot="embed" />
  )}
  <Content />
</ProjectLayout>
